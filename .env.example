# =============================================================================
# PENSY ORDER EXECUTION PLATFORM - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=pensy
APP_ENV=development
# For LIVE trading: set to production
# Options: development, staging, production
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Trading Mode (CRITICAL SAFETY SETTING) ---
# WARNING: Default is PAPER trading (safe mode).
# For LIVE trading:
#   1. Set APP_ENV=production
#   2. Set LIVE_TRADING_ENABLED=true
#   3. Provide REAL Binance API keys
#   4. Use CONSERVATIVE risk profile (see Risk Limits below)
#   5. Confirm via admin API: POST /api/v1/admin/authorize-live-trading
LIVE_TRADING_ENABLED=false
# OPERATOR_CONFIRM_LIVE is set at runtime via the admin API, not here.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://pensy:pensy_dev_password@localhost:5432/pensy
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Binance API (leave empty for paper-only mode) ---
# For LIVE trading:
#   - Get keys from: https://www.binance.com/en/account/api-management
#   - Never commit these to git
#   - Rotate keys regularly
#   - Start with TESTNET (BINANCE_TESTNET=true) to validate setup
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
# Set to true to use Binance testnet endpoints (safe, no real money)

# --- Binance Futures (optional) ---
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=
BINANCE_FUTURES_TESTNET=true

# --- Risk Limits (CONSERVATIVE PROFILE - RECOMMENDED FOR LIVE TRADING) ---
# Start with these conservative limits. Increase gradually as you gain confidence.
# All values in USD equivalent.
MAX_ORDER_NOTIONAL=2000.0
# Maximum notional value per order ($2k conservative, $10k moderate, $50k aggressive)
MAX_ORDER_QUANTITY=10.0
# Maximum quantity per order (10 conservative, 100 moderate, 1000 aggressive)
MAX_POSITION_NOTIONAL=10000.0
# Max total position size ($10k conservative, $50k moderate, $200k aggressive)
MAX_GROSS_EXPOSURE=20000.0
# Max total account exposure ($20k conservative, $100k moderate, $500k aggressive)
MAX_DAILY_LOSS=1000.0
# Stop trading if daily loss reaches this amount ($1k conservative, $5k moderate, $20k aggressive)
MAX_OPEN_ORDERS=5
# Max concurrent open orders (5 conservative, 20 moderate, 50 aggressive)
PRICE_DEVIATION_THRESHOLD=0.02
# Max % price deviation from last trade (2% conservative, 5% moderate, 10% aggressive)
STALE_PRICE_THRESHOLD_SECONDS=30
# Max seconds since last price update before blocking trades
MAX_ORDERS_PER_MINUTE=10
# Rate limit orders (10 conservative, 30 moderate, 60 aggressive)

# --- Symbol Whitelist (comma-separated, STRONGLY RECOMMENDED) ---
# Empty = all symbols allowed (RISKY for live trading)
# Example conservative whitelist (major pairs only):
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
# Add symbols gradually as you gain confidence

# --- Market Data Scraper ---
SCRAPER_INTERVAL_SECONDS=300
# Fetch market data every 5 minutes (300s)
SCRAPER_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT
# Symbols to continuously scrape and update
SCRAPER_OHLCV_INTERVALS=1h,4h,1d
# Candlestick intervals to fetch
SCRAPER_OHLCV_LIMIT=100
# Max bars per interval

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Alert Webhooks (RECOMMENDED for live trading) ---
# Set these up to be notified of risk events
SLACK_WEBHOOK_URL=
# Get from: https://api.slack.com/messaging/webhooks
TELEGRAM_BOT_TOKEN=
# Get bot token from @BotFather on Telegram
TELEGRAM_CHAT_ID=
# Your Telegram chat/user ID

# --- Agent Settings (LLM-assisted trading) ---
AGENT_SKILL_TIMEOUT_SECONDS=30.0
AGENT_MODEL_CONFIDENCE_THRESHOLD=0.5
AGENT_MAX_PIPELINE_TIME_SECONDS=120.0
AGENT_ENABLE_MODEL_ASSISTED=true
LLM_API_KEY=
# Anthropic Claude API key (for AI-assisted trading decisions)
LLM_MODEL_NAME=claude-sonnet-4-20250514
