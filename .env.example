# =============================================================================
# PENSY ORDER EXECUTION PLATFORM - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=pensy
APP_ENV=development
# Options: development, staging, production
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Trading Mode (CRITICAL SAFETY SETTING) ---
# WARNING: Default is PAPER trading. Both flags must be true for live trading.
LIVE_TRADING_ENABLED=false
# OPERATOR_CONFIRM_LIVE is set at runtime via the admin API, not here.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://pensy:pensy_dev_password@localhost:5432/pensy
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Binance API (leave empty for paper-only mode) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
# Set to true to use Binance testnet endpoints

# --- Binance Futures (optional) ---
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=
BINANCE_FUTURES_TESTNET=true

# --- Risk Limits ---
MAX_ORDER_NOTIONAL=10000.0
MAX_ORDER_QUANTITY=100.0
MAX_POSITION_NOTIONAL=50000.0
MAX_GROSS_EXPOSURE=100000.0
MAX_DAILY_LOSS=5000.0
MAX_OPEN_ORDERS=20
PRICE_DEVIATION_THRESHOLD=0.05
STALE_PRICE_THRESHOLD_SECONDS=30
MAX_ORDERS_PER_MINUTE=30

# --- Symbol Whitelist (comma-separated, empty = all allowed) ---
SYMBOL_WHITELIST=BTCUSDT,ETHUSDT,SOLUSDT

# --- Market Data ---
MARKET_DATA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Alert Webhooks (optional) ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
